# =========================
# Python bytecode / cache
# =========================
__pycache__/
*.py[cod]
*$py.class

# =========================
# C extensions
# =========================
*.so

# =========================
# Virtual environments (локальные для каждого проекта)
# =========================
.venv/
venv/
env/
ENV/

# =========================
# IDE / Editor
# =========================
.vscode/
.idea/
*.swp
*.swo

# =========================
# Logs
# =========================
*.log
logs/
*.out
*.err

# =========================
# Environment variables
# =========================
.env
.env.*
!.env.example

# =========================
# Testing
# =========================
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# =========================
# Type checkers
# =========================
.mypy_cache/
.pyre/
.pytype/

# =========================
# Lint
# =========================
.ruff_cache/

# =========================
# Build / packaging
# =========================
build/
dist/
*.egg-info/
.eggs/
*.whl

# =========================
# Jupyter
# =========================
.ipynb_checkpoints/

# =========================
# OS files
# =========================
.DS_Store
Thumbs.db

# =========================
# Docker
# =========================
*.pid
*.seed
*.pid.lock

# =========================
# Alembic (если используешь)
# =========================
alembic/versions/*.pyc

# =========================
# Local DB / artifacts
# =========================
*.sqlite3
*.db

# =========================
# Temporary files
# =========================
tmp/
temp/